# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://quote-reclaim.vercel.app
NEXT_PUBLIC_AUTH_CALLBACK_URL=https://quote-reclaim.vercel.app/api/auth/callback

# Auth providers
# Set to "true" only after Google OAuth is configured in Supabase.
# When unset/false, the Google sign-in button is hidden; Magic Link remains primary.
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Twilio (production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI - Groq is primary
GROQ_API_KEY=
AI_WRITER_PROVIDER=groq
AI_WRITER_MODEL=llama-3.3-70b-versatile
AI_FAST_PROVIDER=groq
AI_FAST_MODEL=llama-3.1-8b-instant

# AI premium (optional, drop-in upgrade)
OPENAI_API_KEY=

# Email (optional channel)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Lemon Squeezy
# Required in production. Pick ONE of the two checkout modes below.
#
# Mode A (preferred): API-created checkouts pin user_id server-side.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
#
# Mode B (fallback): direct store checkout URL. user_id is appended as
# ?checkout[custom][user_id]= so it still reaches the webhook.
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=
#
# Webhook signing secret (required in production).
LEMONSQUEEZY_WEBHOOK_SECRET=

# Cron
CRON_SECRET=

# Monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
