# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://quote-reclaim.vercel.app
NEXT_PUBLIC_AUTH_CALLBACK_URL=https://quote-reclaim.vercel.app/api/auth/callback

# Auth providers
# Set to "true" only after Google OAuth is configured in Supabase.
# When unset/false, the Google sign-in button is hidden; Magic Link remains primary.
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Twilio (production)
# SMS is dormant by default. Set SMS_ENABLED=true only after Twilio A2P is
# registered AND the keys below are set, otherwise the cron will fail closed.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI - Groq is primary
GROQ_API_KEY=
AI_WRITER_PROVIDER=groq
AI_WRITER_MODEL=llama-3.3-70b-versatile
AI_FAST_PROVIDER=groq
AI_FAST_MODEL=llama-3.1-8b-instant

# AI premium (optional, drop-in upgrade)
OPENAI_API_KEY=

# Email — primary delivery channel
# Required for cron to send recovery follow-ups. Domain must be verified on
# Resend; "from" address defaults to hello@quotereclaim.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Signing secret for the Resend open/click webhook (Quiet Signal), required in
# production for /api/webhooks/resend-email-events. This is a DEDICATED secret:
# Resend issues a different signing secret per webhook endpoint. Do NOT reuse
# the inbound/reply webhook's secret (EMAIL_INBOUND_SECRET) here, and do NOT
# overwrite this with any other webhook's secret.
RESEND_EMAIL_EVENTS_WEBHOOK_SECRET=

# Billing
# Quote Reclaim is currently between merchants of record. There is no active
# billing provider in code: the upgrade UI surfaces an honest "billing being
# updated — email support@quotereclaim.com" message instead of calling a
# dead checkout route. When a future provider (Paddle / Stripe-via-MoR /
# etc.) is wired up, add its env vars here and replace the disabled provider
# in src/lib/payments/provider.ts.

# Cron
CRON_SECRET=

# Monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
