# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://quote-reclaim.vercel.app
NEXT_PUBLIC_AUTH_CALLBACK_URL=https://quote-reclaim.vercel.app/api/auth/callback

# Auth providers
# Set to "true" only after Google OAuth is configured in Supabase.
# When unset/false, the Google sign-in button is hidden; Magic Link remains primary.
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Twilio (production)
# SMS is dormant by default. Set SMS_ENABLED=true only after Twilio A2P is
# registered AND the keys below are set, otherwise the cron will fail closed.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI - Groq is primary
GROQ_API_KEY=
AI_WRITER_PROVIDER=groq
AI_WRITER_MODEL=llama-3.3-70b-versatile
AI_FAST_PROVIDER=groq
AI_FAST_MODEL=llama-3.1-8b-instant

# AI premium (optional, drop-in upgrade)
OPENAI_API_KEY=

# Email — primary delivery channel
# Required for cron to send recovery follow-ups. Domain must be verified on
# Resend; "from" address defaults to hello@quotereclaim.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Signing secret for the Resend open/click webhook (Quiet Signal), required in
# production for /api/webhooks/resend-email-events. This is a DEDICATED secret:
# Resend issues a different signing secret per webhook endpoint. Do NOT reuse
# the inbound/reply webhook's secret (EMAIL_INBOUND_SECRET) here, and do NOT
# overwrite this with any other webhook's secret.
RESEND_EMAIL_EVENTS_WEBHOOK_SECRET=

# Billing — Paddle
#
# When NEXT_PUBLIC_PADDLE_CLIENT_TOKEN and NEXT_PUBLIC_PADDLE_PRICE_ID are set,
# the UI opens Paddle.js overlay checkout for the $79/month subscription.
# When they are unset, the UI falls back to the honest "billing is being
# updated — email support@quotereclaim.com" state. Either branch is safe.
#
# - NEXT_PUBLIC_PADDLE_CLIENT_TOKEN: public client-side token (safe in the
#   browser; ships in the bundle).
# - NEXT_PUBLIC_PADDLE_PRICE_ID: priced subscription item id (e.g. pri_...).
# - NEXT_PUBLIC_PADDLE_ENVIRONMENT: "sandbox" or "production". Defaults to
#   production when unset, so a missing/typoed var never silently opens
#   sandbox checkout in front of a real contractor.
# - PADDLE_API_KEY: server-side API key. Reserved for future use (e.g.
#   customer-portal links); the webhook flow does not need it.
# - PADDLE_WEBHOOK_SECRET: HMAC-SHA256 signing secret for /api/webhooks/paddle.
#   Production fails closed (503) if this is unset. Get it from the Paddle
#   dashboard → Developer tools → Notifications, per-endpoint.
# - NEXT_PUBLIC_PADDLE_DEBUG: set to "true" TEMPORARILY to log a safe checkout
#   preflight (booleans + env classification + a REDACTED payload — never the
#   token/secret) to the browser console. Leave unset/blank in normal prod.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_ID=
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_DEBUG=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Cron
CRON_SECRET=

# Monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
